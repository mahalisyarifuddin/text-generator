    "import os, json, ctypes\n",
    "from collections import Counter\n",
    "from IPython.display import HTML, display\n",
    "\n",
    "def mulberry32(a):\n",
    "    state = a & 0xFFFFFFFF\n",
    "    def next_val():\n",
    "        nonlocal state\n",
    "        state = (state + 0x6D2B79F5) & 0xFFFFFFFF\n",
    "        t = state\n",
    "        def imul(a, b):\n",
    "            return ctypes.c_int32(ctypes.c_int32(a).value * ctypes.c_int32(b).value).value\n",
    "        m1 = imul(t ^ (t >> 15), t | 1)\n",
    "        t = m1 & 0xFFFFFFFF\n",
    "        m2 = imul(t ^ (t >> 7), t | 61)\n",
    "        t = (t ^ (t + m2)) & 0xFFFFFFFF\n",
    "        res = (t ^ (t >> 14)) & 0xFFFFFFFF\n",
    "        return res / 4294967296.0\n",
    "    return next_val\n",
