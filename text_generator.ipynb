   "source": [
    "# Just Another Test Text Generator (Colab Version)\n",
    "This notebook converts a text corpus into a trigram TSV and generates text from a trigram TSV. Ported from [Tim Ahrens' Generator](http://justanotherfoundry.com/generator)."
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Corpus to Trigrams TSV\n",
    "Enter text below to convert it into a trigram TSV file."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import re\n",
    "from collections import Counter\n",
    "try:\n",
    "    from google.colab import files\n",
    "except ImportError:\n",
    "    files = None\n",
    "\n",
    "def corpus_to_trigrams(text, filename=\"input\"):\n",
    "    # Replace all whitespace sequences with a single underscore\n",
    "    text = re.sub(r'\\s+', '_', text)\n",
    "    \n",
    "    # Ensure bootstrap marker exists\n",
    "    if not text.startswith(\"._\"): \n",
    "        text = \"._\" + text\n",
    "\n",
    "    # Word length counting (ignoring bootstrap marker)\n",
    "    clean_words = text[2:].strip('_').split('_')\n",
    "    word_lengths = Counter()\n",
    "    for word in clean_words:\n",
    "        if word:\n",
    "            length = len(word)\n",
    "            if 1 <= length <= 50:\n",
    "                word_lengths[length] += 1\n",
    "                \n",
    "    # Trigram counting\n",
    "    trigrams = Counter()\n",
    "    for i in range(len(text) - 2):\n",
    "        tri = text[i:i+3]\n",
    "        trigrams[tri] += 1\n",
    "        \n",
    "    lines = [f\"combined from {filename}\"]\n",
    "    for i in range(1, 51):\n",
    "        count = word_lengths.get(i, 0)\n",
    "        lines.append(f\"{count}\\tword{i:03d}\")\n",
    "        \n",
    "    sorted_trigrams = sorted(trigrams.items(), key=lambda x: (x[1], x[0]))\n",
    "    for tri, count in sorted_trigrams:\n",
    "        if count > 0:\n",
    "            lines.append(f\"{count}\\t{tri}\")\n",
    "            \n",
    "    return \"\\n\".join(lines) + \"\\n\"\n",
    "\n",
    "# @title Convert Text to TSV\n",
    "input_text = \"The quick brown fox jumps over the lazy dog.\" #@param {type:\"string\"}\n",
    "output_filename = \"my_trigrams.tsv\" #@param {type:\"string\"}\n",
    "\n",
    "if input_text:\n",
    "    tsv_output = corpus_to_trigrams(input_text)\n",
    "    with open(output_filename, \"w\", encoding=\"utf-8\") as f:\n",
    "        f.write(tsv_output)\n",
    "    print(f\"Saved to {output_filename}\")\n",
    "    if files:\n",
    "        files.download(output_filename)\n"
   ]
  },
