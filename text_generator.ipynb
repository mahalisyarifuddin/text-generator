    "def generate():\n",
    "    random_gen = mulberry32(seed)\n",
    "    if not os.path.exists(tsv_file):\n",
    "        print(f\"Error: {tsv_file} not found.\")\n",
    "        return\n",
    "    with open(tsv_file, 'r', encoding='utf-8') as f:\n",
    "        all_inputs = f.readlines()\n",
    "    if not all_inputs: return\n",
    "    del all_inputs[0]\n",
    "    \n",
    "    wordlen_in = [1]*51\n",
    "    wordmax = 6\n",
    "    wordsum_in = wordmax\n",
    "    \n",
    "    while all_inputs:\n",
    "        line = all_inputs[0].strip()\n",
    "        if not line: del all_inputs[0]; continue\n",
    "        parts = line.split('\\t')\n",
    "        if len(parts) < 2: del all_inputs[0]; continue\n",
    "        count_val, key = int(parts[0]), parts[1].strip()\n",
    "        if key.startswith('word'):\n",
    "            idx = int(key[4:7])\n",
    "            if idx < 51:\n",
    "                wordlen_in[idx] += count_val\n",
    "                wordsum_in += count_val\n",
    "            del all_inputs[0]\n",
    "        else: break\n",
    "        \n",
    "    characters = ''\n",
    "    if characters_filter.strip() != \"\":\n",
    "        cf_clean = characters_filter.replace(\" \", \"\").replace(\"\\t\", \"\").replace(\"\\n\", \"\").replace(\"\\r\", \"\")\n",
    "        for c in cf_clean:\n",
    "            if case_mode == \"allcaps\" and c in casedict: characters += casedict[c]\n",
    "            else:\n",
    "                if c != '\\u00DF': characters += c\n",
    "    \n",
    "    characters_for_filter = \"_\" + characters if characters != \"\" else \"\"\n",
    "    \n",
    "    duplets = {}\n",
    "    for inp in all_inputs:\n",
    "        parts = inp.strip().split('\\t')\n",
    "        if len(parts) < 2: continue\n",
    "        v = int(parts[0])\n",
    "        t = parts[1]\n",
    "        \n",
    "        processed_t = ''\n",
    "        for char in t:\n",
    "            if case_mode == \"allcaps\" and char in casedict: processed_t += casedict[char]\n",
    "            else: processed_t += char\n",
    "        \n",
    "        if case_mode == \"capitalized\":\n",
    "            if (processed_t[0] == '_' and processed_t[1] in casedict) or (processed_t[1] == '_' and processed_t[2] in casedict): continue\n",
    "        \n",
    "        if characters_for_filter != \"\":\n",
    "            if not all(c in characters_for_filter for c in processed_t): continue\n",
    "            \n",
    "        d_key, d_val = processed_t[0:2], processed_t[2]\n",
    "        if d_key not in duplets: duplets[d_key] = {}\n",
    "        duplets[d_key][d_val] = duplets[d_key].get(d_val, 0) + v\n",
    "        \n",
    "    # Clean dead ends\n",
    "    for _ in range(2):\n",
    "        to_delete_d = []\n",
    "        for d in duplets:\n",
    "            to_delete_v = []\n",
    "            for v in duplets[d]:\n",
    "                if d[1]+v not in duplets: to_delete_v.append(v)\n",
    "            for v in to_delete_v: del duplets[d][v]\n",
    "            if not duplets[d]: to_delete_d.append(d)\n",
    "        for d in to_delete_d: del duplets[d]\n",
    "            \n",
    "    kernglobal = {\"s3\":-1.0, \"s2\":-0.6, \"s1\":-0.3, \"0\":0, \"b1\":0.3, \"b2\":0.6, \"b3\":0.9}.get(kerning_level, 0)\n",
    "    kerntweaks = {}\n",
    "    if kernglobal != 0:\n",
    "        if kerning_mode == \"typical\":\n",
    "            for kp, val in kerning_data_full.items():\n",
    "                kerntweaks[kp] = 1.0 * val**kernglobal\n",
    "        elif kerning_mode == \"custom\":\n",
    "            for kp in custom_kern_pairs.split():\n",
    "                kerntweaks[kp] = 100.0 ** kernglobal\n",
    "                \n",
    "    equalisation = 0.007 * letter_variety\n",
    "    equalis_pair = 0.01 * pair_variety\n",
    "    wordlen_out = [1]*51\n",
    "    wordsum_out = wordmax - 2\n",
    "    \n",
    "    if characters != \"\" and \".\" not in characters:\n",
    "        pool_c = \"_\" + characters\n",
    "        current = pool_c[int(random_gen() * len(pool_c))] + \"_\"\n",
    "    else:\n",
    "        current = \"._\"\n",
    "        \n",
    "    if current not in duplets and duplets:\n",
    "        all_keys = sorted(list(duplets.keys()))\n",
    "        current = all_keys[int(random_gen() * len(all_keys))]\n",
    "    \n",
    "    wordtmp, file_output = 0, \"\"\n",
    "    freq_m, freq_total, num_l = {}, 1, 0\n",
    "    freq_m_uc, freq_total_uc, num_l_uc = {}, 1, 0\n",
    "    pair_m, pair_total, num_p = {}, 1, 0\n",
    "    \n",
    "    for i in range(text_length):\n",
    "        if current[1] in letters: wordtmp += 1\n",
    "        else:\n",
    "            if current[0] in letters:\n",
    "                wlen = min(wordtmp, wordmax)\n",
    "                wordlen_out[wlen] += 1\n",
    "                wordsum_out += 1\n",
    "            wordtmp = 0\n",
    "        \n",
    "        tweakblank = 1\n",
    "        if wordtmp >= wordmax: tweakblank = (wordtmp - wordmax + 1) * 60\n",
    "        elif wordtmp != 0:\n",
    "            tweakblank = (1.0 * (wordlen_in[min(wordtmp,50)]*wordsum_out) / (wordlen_out[min(wordtmp,50)]*wordsum_in))**4\n",
    "            if wordtmp > 15 and tweakblank < equalisation*50: tweakblank = equalisation*50 + 2\n",
    "            tweakblank = max(0.25, min(30.0, tweakblank))\n",
    "            \n",
    "        if current in duplets and duplets[current]:\n",
    "            cumulative, sum_val, options = [], 1, sorted(duplets[current].items())\n",
    "            for j, v in options:\n",
    "                mult = 2**(characters.count(j)-1) if characters else 1\n",
    "                if j in lowercase+arabic:\n",
    "                    if j not in freq_m: freq_m[j] = 1; num_l += 1\n",
    "                    tweakl = 1.0 + equalisation * ((freq_total/freq_m[j]/num_l)*5 - 1)\n",
    "                elif j in uppercase:\n",
    "                    if j not in freq_m_uc: freq_m_uc[j] = 1; num_l_uc += 1\n",
    "                    tweakl = 1.0 + equalisation * ((freq_total_uc/freq_m_uc[j]/num_l_uc)*5 - 1)\n",
    "                else: tweakl = tweakblank\n",
    "                \n",
    "                pair = current[1] + j\n",
    "                if pair not in pair_m: pair_m[pair] = 4; num_p += 1\n",
    "                tweakp = 1.0 if \"_\" in pair else 1.0 + equalis_pair * ((pair_total/pair_m[pair]/num_p)*5 - 1)\n",
    "                tweakkern = kerntweaks.get(pair, 1)\n",
    "                sum_val += v * tweakl * tweakp * tweakkern * mult\n",
    "                cumulative.append(sum_val)\n",
    "            \n",
    "            correction = 55000.0 / sum_val\n",
    "            randm = int(random_gen() * 55000)\n",
    "            chosen_next = options[-1][0]\n",
    "            for k in range(len(cumulative)):\n",
    "                if randm < int(cumulative[k] * correction):\n",
    "                    chosen_next = options[k][0]\n",
    "                    break\n",
    "            \n",
    "            current = current[1] + chosen_next\n",
    "            file_output += chosen_next.replace(\"_\", \" \")\n",
    "            if chosen_next in freq_m: freq_m[chosen_next] += 1; freq_total += 1\n",
    "            if chosen_next in freq_m_uc: freq_m_uc[chosen_next] += 1; freq_total_uc += 1\n",
    "            if current in pair_m: pair_m[current] += 1; pair_total += 1\n",
    "        else:\n",
    "            pool = \"____\" + (characters if characters else \".....,,,,!?\")\n",
    "            chosen_next = pool[int(random_gen() * len(pool))]\n",
    "            current = current[1] + chosen_next\n",
    "            file_output += chosen_next.replace(\"_\", \" \")\n",
    "            \n",
    "    print(file_output)\n",
    "    # Character Frequency Analysis (TSV)\n",
    "    char_counts = Counter(file_output)\n",
    "    total_chars = len(file_output)\n",
    "    sorted_chars = sorted(char_counts.items(), key=lambda x: x[1], reverse=True)\n",
    "    \n",
    "    tsv_lines = [\"Character\\tCount\\tPercentage\"]\n",
    "    for char, count in sorted_chars:\n",
    "        display_char = char if char != \" \" else \"Space\"\n",
    "        percentage = (count / total_chars) * 100\n",
    "        tsv_lines.append(f\"{display_char}\\t{count}\\t{percentage:.2f}%\")\n",
    "    \n",
    "    tsv_output = \"\\n\".join(tsv_lines)\n",
    "    html_output = f\"\"\"\n",
    "    <details>\n",
    "        <summary><b>Character Frequency Analysis</b> (Click to expand)</summary>\n",
    "        <textarea style=\"width: 100%; height: 200px; font-family: monospace; margin-top: 10px;\" readonly>{tsv_output}</textarea>\n",
    "    </details>\n",
    "    \"\"\"\n",
    "    display(HTML(html_output))\n",
    "generate()\n"
   ]
  }
